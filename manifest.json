{
  "manifest_version": 3,
  "name": "FlowWatch: A Neuro-Adaptive Focus Timer",
  "version": "1.0",
  "description": "A focus timer that adapts to your flow state, with dynamically calculated break times.",
  "options_page": "record.html",
  "permissions": ["storage", "alarms", "notifications", "offscreen", "scripting", "activeTab"],
  "action": {
    "default_icon": {
      "48": "images/icon48.png",
      "96": "images/icon96.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "48": "images/icon48.png",
    "96": "images/icon96.png"
  }
}
